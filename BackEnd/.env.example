# Server
PORT=3001
CORS_ORIGIN=http://localhost:8080
STRATEGY_SCHEDULER_POLL_MS=15000
MINER_POLL_MS=15000
MINER_SECRET_KEY=change-me
# STRATEGY_STORE_PATH=./data/strategy-store.json

# Binance credentials
# Leave empty to connect with session credentials from the frontend Settings page.
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=false

# Portfolio shaping
MAX_ASSETS=20
MIN_ASSET_VALUE_USD=1

# Demo account (Automation panel uses these with live market prices)
DEMO_ACCOUNT_CAPITAL=10000
DEMO_ACCOUNT_ALLOCATION=BTC:40,ETH:30,BNB:10,USDC:20

# Optional NiceHash API wallet status (for NiceHash tab)
# Key permissions needed:
# - Wallet / View balances transactions and deposit addresses (VBTD)
# - Mining / View mining data and statistics (VMDS)
NICEHASH_API_KEY=
NICEHASH_API_SECRET=
NICEHASH_ORG_ID=
NICEHASH_API_HOST=https://api2.nicehash.com

# Optional Crypto.com Exchange wallet status (for Exchanges > Connections)
# Use a read-enabled Exchange API key.
CRYPTO_COM_API_KEY=
CRYPTO_COM_API_SECRET=
CRYPTO_COM_API_HOST=https://api.crypto.com

# Optional mining and NiceHash inputs
# MINERS_BASIC_JSON=[{"id":"miner-1","name":"Antminer S19","model":"S19","status":"online","hashrateTH":95,"powerW":3250,"pool":"NiceHash","lastSeen":"2026-03-11T00:00:00Z","estimatedDailyRevenueUSD":9.5}]
